{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "arbeitsorganisator",
  "version": "0.4.0",
  "identifier": "com.martina.arbeitsorganisator",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "arbeitsorganisator",
        "width": 800,
        "height": 600,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "width": 300,
        "height": 300,
        "decorations": false,
        "transparent": true,
        "center": true,
        "resizable": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": { "signingIdentity": "-" }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc4QTAzMzBBRkQ1RUFBRjUKUldUMXFsNzlDak9nZVA0bDA4RlBISUdSZU1pWWZtNVR3emZsVjlkeFB0TE8wdHdTZWVKV1BGd1kK",
      "endpoints": [
        "https://github.com/axkony/arbeitsorganisator/releases/latest/download/latest.json"
      ]
    }
  }
}
